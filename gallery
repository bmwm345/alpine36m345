<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gallery — E36 M3</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Cormorant+Garant:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #080808; --surface: #111; --border: #1e1e1e;
      --text: #e0e0e0; --muted: #666; --dim: #999;
      --red: #c0392b; --red-bright: #e74c3c;
      --blue: #1c5fa8; --blue-bright: #3498db;
      --m-blue: #1c5fa8; --m-dark: #0a3a7a; --m-red: #c0392b;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--black); color: var(--text); font-family: 'Cormorant Garant', serif; overflow-x: hidden; }

    /* Fixed badge */
    .fixed-badge { position: fixed; top: 20px; left: 28px; z-index: 1000; display: flex; align-items: center; gap: 6px; }
    .fixed-badge .stripes { display: flex; gap: 2px; }
    .fixed-badge .stripe { width: 4px; height: 28px; border-radius: 1px; }
    .fixed-badge .stripe.blue     { background: var(--m-blue); }
    .fixed-badge .stripe.darkblue { background: var(--m-dark); }
    .fixed-badge .stripe.red      { background: var(--m-red); }
    .fixed-badge .badge-text { display: flex; align-items: baseline; filter: drop-shadow(0 0 12px rgba(192,57,43,0.4)); }
    .fixed-badge .m-logo, .fixed-badge .three { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 1.6rem; color: #fff; letter-spacing: -0.02em; text-shadow: 0 0 20px rgba(255,255,255,0.2), 0 2px 6px rgba(0,0,0,0.9); }

    /* Sticky nav */
    .sticky-nav { position: fixed; top: 0; left: 0; width: 100%; z-index: 999; background: rgba(8,8,8,0.95); backdrop-filter: blur(14px); border-bottom: 1px solid var(--border); display: flex; justify-content: center; padding: 0 20px; transform: translateY(-100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); }
    .sticky-nav.visible { transform: translateY(0); }
    .sticky-nav::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, var(--m-blue) 0%, var(--m-dark) 33%, var(--m-red) 66%, transparent 100%); }
    .sticky-nav a { font-family: 'Rajdhani', sans-serif; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--dim); text-decoration: none; padding: 20px 24px; position: relative; transition: color 0.25s; }
    .sticky-nav a:first-child { margin-left: 80px; }
    .sticky-nav a::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 0; height: 2px; background: var(--red-bright); transition: width 0.3s; }
    .sticky-nav a:hover { color: #fff; }
    .sticky-nav a:hover::after { width: 60%; }
    .sticky-nav a.active { color: #fff; }
    .sticky-nav a.active::after { width: 60%; background: var(--red); }

    /* Hero */
    .hero { position: relative; width: 100%; height: 65vh; min-height: 420px; display: flex; align-items: flex-end; justify-content: center; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0a0a0a 0%, #0f1a2e 40%, #1a0808 70%, #0a0a0a 100%); background-size: cover; background-position: center; transform: scale(1.04); animation: heroZoom 10s ease-out forwards; }
    @keyframes heroZoom { from { transform: scale(1.04); } to { transform: scale(1); } }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(8,8,8,0.2) 0%, rgba(8,8,8,0.05) 40%, rgba(8,8,8,0.7) 80%, rgba(8,8,8,1) 100%); }
    .hero-label { position: relative; z-index: 2; text-align: center; padding-bottom: 48px; animation: fadeUp 1s 0.4s ease both; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .hero-label h1 { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 0.72rem; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
    .hero-label p { font-family: 'Cormorant Garant', serif; font-size: 1.5rem; font-weight: 300; font-style: italic; color: rgba(255,255,255,0.75); }
    .hero-rule { width: 36px; height: 2px; background: var(--red); margin: 12px auto; }
    .hero-nav { position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; }
    .hero-nav a { font-family: 'Rajdhani', sans-serif; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.4); text-decoration: none; padding: 10px 18px; transition: color 0.25s; border-bottom: 1px solid transparent; }
    .hero-nav a:hover { color: rgba(255,255,255,0.85); border-bottom-color: var(--red); }

    /* Gallery section */
    .gallery-section { max-width: 1100px; width: 92%; margin: 70px auto 120px; animation: fadeUp 0.8s 0.2s ease both; }

    .gallery-header { text-align: center; margin-bottom: 50px; }
    .gallery-header h2 { font-family: 'Orbitron', sans-serif; font-size: 1rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #fff; margin-bottom: 16px; }
    .gallery-header p { font-family: 'Cormorant Garant', serif; font-size: 1.05rem; font-weight: 300; font-style: italic; color: var(--dim); }
    .gallery-header-rule { width: 36px; height: 2px; background: var(--red); margin: 16px auto; }

    /* Filter tabs */
    .filter-tabs { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; margin-bottom: 44px; }
    .filter-tab { font-family: 'Rajdhani', sans-serif; font-size: 0.64rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dim); background: transparent; border: 1px solid var(--border); padding: 8px 18px; cursor: pointer; transition: all 0.2s; }
    .filter-tab:hover { color: #fff; border-color: var(--dim); }
    .filter-tab.active { color: #fff; border-color: var(--red); background: rgba(192,57,43,0.08); }

    /* Masonry grid */
    .masonry { columns: 3; column-gap: 10px; }
    @media (max-width: 900px) { .masonry { columns: 2; } }
    @media (max-width: 500px) { .masonry { columns: 1; } }

    .photo-card { break-inside: avoid; margin-bottom: 10px; position: relative; overflow: hidden; cursor: pointer; background: var(--surface); display: block; }

    /* Placeholder cards — remove once real images are added */
    .photo-card .placeholder { width: 100%; background: var(--surface); display: flex; align-items: center; justify-content: center; }
    .photo-card .placeholder span { font-family: 'Rajdhani', sans-serif; font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: #333; }

    .photo-card img { width: 100%; display: block; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }
    .photo-card:hover img { transform: scale(1.04); }

    /* Caption overlay */
    .photo-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 14px 14px; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%); opacity: 0; transform: translateY(6px); transition: opacity 0.3s, transform 0.3s; }
    .photo-card:hover .photo-caption { opacity: 1; transform: translateY(0); }
    .photo-caption p { font-family: 'Rajdhani', sans-serif; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.85); margin: 0; }
    .photo-caption span { font-family: 'Cormorant Garant', serif; font-size: 0.8rem; font-style: italic; color: var(--dim); }

    /* Lightbox */
    .lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 2000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox img { max-width: 90vw; max-height: 88vh; display: block; border: 1px solid var(--border); }
    .lightbox-close { position: absolute; top: 24px; right: 30px; font-family: 'Rajdhani', sans-serif; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dim); cursor: pointer; transition: color 0.2s; background: none; border: none; }
    .lightbox-close:hover { color: #fff; }
    .lightbox-caption { position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%); font-family: 'Rajdhani', sans-serif; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--dim); white-space: nowrap; }

    /* Add photo hint */
    .add-hint { text-align: center; margin-top: 60px; padding: 32px; border: 1px dashed var(--border); }
    .add-hint p { font-family: 'Rajdhani', sans-serif; font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin: 0; line-height: 2; }
    .add-hint code { font-size: 0.72rem; color: var(--blue-bright); background: rgba(28,95,168,0.08); padding: 2px 6px; }

    footer { border-top: 1px solid var(--border); padding: 32px 20px; text-align: center; font-family: 'Rajdhani', sans-serif; font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); }
  </style>
</head>
<body>

  <div class="fixed-badge">
    <div class="stripes"><div class="stripe blue"></div><div class="stripe darkblue"></div><div class="stripe red"></div></div>
    <div class="badge-text"><span class="m-logo">M</span><span class="three">3</span></div>
  </div>

  <nav class="sticky-nav" id="stickyNav">
    <a href="index.html">Home</a>
    <a href="about.html">About</a>
    <a href="gallery.html" class="active">Gallery</a>
    <a href="maintenance.html">Maintenance</a>
  </nav>

  <section class="hero">
    <div class="hero-bg" id="heroBg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-label">
      <h1>Gallery</h1>
      <div class="hero-rule"></div>
      <p>Alpine White. Every angle.</p>
    </div>
    <div class="hero-nav">
      <a href="index.html">Home</a>
      <a href="about.html">About</a>
      <a href="gallery.html">Gallery</a>
      <a href="maintenance.html">Maintenance</a>
    </div>
  </section>

  <div class="gallery-section">
    <div class="gallery-header">
      <h2>The Car</h2>
      <div class="gallery-header-rule"></div>
      <p>Drop your photos in <code>images/gallery/</code> and update the src attributes below.</p>
    </div>

    <!-- Filter tabs — add/remove categories to match your photos -->
    <div class="filter-tabs">
      <button class="filter-tab active" data-filter="all">All</button>
      <button class="filter-tab" data-filter="exterior">Exterior</button>
      <button class="filter-tab" data-filter="interior">Interior</button>
      <button class="filter-tab" data-filter="engine">Engine</button>
      <button class="filter-tab" data-filter="detail">Detail</button>
    </div>

    <!-- 
      HOW TO ADD YOUR PHOTOS:
      1. Put images in an "images/gallery/" folder next to your HTML files.
      2. Replace each placeholder <div class="placeholder"> with:
         <img src="images/gallery/your-photo.jpg" alt="description">
      3. Update the data-category on each .photo-card to match your filter tabs.
      4. Update .photo-caption text to whatever you want shown on hover.
      5. Delete the .add-hint block at the bottom once you're done.
    -->

    <div class="masonry" id="masonryGrid">

      <div class="photo-card" data-category="exterior" data-caption="Front three-quarter" data-sub="Alpine White · S52">
        <div class="placeholder" style="height:280px"><span>images/gallery/photo-01.jpg</span></div>
        <div class="photo-caption"><p>Front three-quarter</p><span>Alpine White · S52</span></div>
      </div>

      <div class="photo-card" data-category="engine" data-caption="S52B32" data-sub="3.2L Inline-Six">
        <div class="placeholder" style="height:220px"><span>images/gallery/photo-02.jpg</span></div>
        <div class="photo-caption"><p>S52B32</p><span>3.2L Inline-Six</span></div>
      </div>

      <div class="photo-card" data-category="exterior" data-caption="Rear three-quarter" data-sub="Style 39 Sunflowers">
        <div class="placeholder" style="height:320px"><span>images/gallery/photo-03.jpg</span></div>
        <div class="photo-caption"><p>Rear three-quarter</p><span>Style 39 Sunflowers</span></div>
      </div>

      <div class="photo-card" data-category="interior" data-caption="Driver's seat" data-sub="Factory interior">
        <div class="placeholder" style="height:240px"><span>images/gallery/photo-04.jpg</span></div>
        <div class="photo-caption"><p>Driver's seat</p><span>Factory interior</span></div>
      </div>

      <div class="photo-card" data-category="detail" data-caption="M badge" data-sub="///M Division">
        <div class="placeholder" style="height:200px"><span>images/gallery/photo-05.jpg</span></div>
        <div class="photo-caption"><p>M badge</p><span>///M Division</span></div>
      </div>

      <div class="photo-card" data-category="exterior" data-caption="Side profile" data-sub="4-door · Sedan">
        <div class="placeholder" style="height:260px"><span>images/gallery/photo-06.jpg</span></div>
        <div class="photo-caption"><p>Side profile</p><span>4-door · Sedan</span></div>
      </div>

      <div class="photo-card" data-category="engine" data-caption="Valve cover" data-sub="Post spark plug R&R">
        <div class="placeholder" style="height:230px"><span>images/gallery/photo-07.jpg</span></div>
        <div class="photo-caption"><p>Valve cover</p><span>Post spark plug R&R</span></div>
      </div>

      <div class="photo-card" data-category="detail" data-caption="Style 39 Sunflower" data-sub="Aluminum alloy">
        <div class="placeholder" style="height:270px"><span>images/gallery/photo-08.jpg</span></div>
        <div class="photo-caption"><p>Style 39 Sunflower</p><span>Aluminum alloy</span></div>
      </div>

      <div class="photo-card" data-category="interior" data-caption="Instrument cluster" data-sub="166,000+ miles">
        <div class="placeholder" style="height:210px"><span>images/gallery/photo-09.jpg</span></div>
        <div class="photo-caption"><p>Instrument cluster</p><span>166,000+ miles</span></div>
      </div>

    </div><!-- end masonry -->

    <div class="add-hint">
      <p>
        To add your photos: place images in <code>images/gallery/</code> and replace<br>
        the placeholder divs with <code>&lt;img src="images/gallery/filename.jpg"&gt;</code><br>
        — then delete this hint block.
      </p>
    </div>

  </div><!-- end gallery-section -->

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">✕ Close</button>
    <img src="" alt="" id="lightboxImg">
    <div class="lightbox-caption" id="lightboxCaption"></div>
  </div>

  <footer>@s52alpine</footer>

  <script>
    // Sticky nav
    const nav = document.getElementById('stickyNav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('visible', window.scrollY > document.querySelector('.hero').offsetHeight * 0.5);
    });

    // Hero image
    const heroBg = document.getElementById('heroBg');
    const t = new Image();
    t.onload = () => { heroBg.style.backgroundImage = 'linear-gradient(to bottom, rgba(8,8,8,0.25) 0%, rgba(8,8,8,0.05) 40%, rgba(8,8,8,0.65) 78%, rgba(8,8,8,1) 100%), url("images/hero.jpg")'; };
    t.src = 'images/hero.jpg';

    // Filter tabs
    const tabs = document.querySelectorAll('.filter-tab');
    const cards = document.querySelectorAll('.photo-card');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        cards.forEach(card => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.style.display = show ? 'block' : 'none';
        });
      });
    });

    // Lightbox — only works once real <img> tags are added
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');
    const lightboxCaption = document.getElementById('lightboxCaption');
    const lightboxClose = document.getElementById('lightboxClose');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const img = card.querySelector('img');
        if (!img) return; // no-op until real images are added
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightboxCaption.textContent = card.dataset.caption || '';
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
    }
  </script>
</body>
</html>
